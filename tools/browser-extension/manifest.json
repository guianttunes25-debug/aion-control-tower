{
  "manifest_version": 3,
  "name": "AION Browser Autopilot",
  "description": "Operador local com autorizacao humana para pesquisar, observar e preparar acoes em paginas abertas.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:8080/*",
    "https://www.google.com/*",
    "https://www.coursera.org/*",
    "https://www.edx.org/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "AION Autopilot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}